@using Microsoft.AspNetCore.Http.Extensions
@using MailArchiver.Services
@using MailArchiver.Models.ViewModels
@inject MailArchiver.Services.IAuthenticationService AuthService
@inject Microsoft.Extensions.Localization.IStringLocalizer<MailArchiver.SharedResource> Localizer
@model MailArchiver.Models.ViewModels.SearchViewModel
@{
    ViewData["Title"] = Localizer["EmailArchive"];
    var folderTree = ViewBag.FolderTree as List<FolderTreeNode> ?? new List<FolderTreeNode>();
}

@* Anti-Forgery Token für JavaScript *@
@Html.AntiForgeryToken()

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3">@Localizer["EmailArchive"]</h1>
        <button type="button" id="folderTreeMobileToggle" class="btn btn-outline-secondary folder-tree-mobile-toggle @(Model.SelectedAccountId.HasValue ? "" : "folder-tree-unavailable")" data-bs-toggle="offcanvas" data-bs-target="#folderTreeOffcanvas">
            <i class="bi bi-folder"></i> <span>@Localizer["Folders"]</span>
        </button>
    </div>

    @* Active Jobs Alert *@
    @if (User.IsInRole("Admin") && ViewBag.ActiveJobsCount != null && ViewBag.ActiveJobsCount > 0)
    {
        <div class="alert alert-info alert-dismissible fade show">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2">
                <div>
                    <i class="bi bi-clock-history me-2"></i>
                    <strong>@ViewBag.ActiveJobsCount</strong> background job(s) are currently running.
                </div>
                <div>
                    <a asp-action="Jobs" class="btn btn-outline-primary btn-sm me-2">
                        <i class="bi bi-eye me-1"></i> View Jobs
                    </a>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        </div>
    }

    <div class="card mb-4">
        <div class="card-header">
            <h6 class="mb-0">@Localizer["Search"]</h6>
        </div>
        <div class="card-body">
            <form asp-action="Index" method="get" id="searchForm">
                <div class="row">
                    <div class="col-12 col-md-6 col-lg-3 mb-3">
                        <label asp-for="SearchTerm" class="form-label">@Localizer["SearchTerm"]</label>
                        <input asp-for="SearchTerm" class="form-control form-control-sm" placeholder="@Localizer["SubjectSender"]" />
                        <div class="form-text small text-muted">
                            <i class="bi bi-info-circle me-1"></i>
                            <strong>@Localizer["AdvancedSearch"]</strong><br>
                            @Localizer["AdvancedSearchInfo1"]<br>
                            @Localizer["AdvancedSearchInfo2"]<br>
                            @Localizer["AdvancedSearchInfo3"]
                        </div>
                    </div>
                    <div class="col-6 col-md-3 col-lg-2 mb-3">
                        <label asp-for="FromDate" class="form-label">@Localizer["FromDate"]</label>
                        <input asp-for="FromDate" class="form-control form-control-sm" type="date" />
                    </div>
                    <div class="col-6 col-md-3 col-lg-2 mb-3">
                        <label asp-for="ToDate" class="form-label">@Localizer["ToDate"]</label>
                        <input asp-for="ToDate" class="form-control form-control-sm" type="date" />
                    </div>
                    <div class="col-12 col-md-6 col-lg-2 mb-3">
                        <label asp-for="SelectedAccountId" class="form-label">@Localizer["Account"]</label>
                        <select asp-for="SelectedAccountId" asp-items="Model.AccountOptions" class="form-select form-select-sm" id="accountSelect"></select>
                    </div>
                    <div class="col-12 col-md-6 col-lg-2 mb-3" id="folderFilterContainer" style="@(Model.SelectedAccountId.HasValue ? "" : "display: none;")">
                        <label asp-for="SelectedFolder" class="form-label">@Localizer["Folder"]</label>
                        <select asp-for="SelectedFolder" id="folderSelect" class="form-select form-select-sm">
                            <option value="">@Localizer["AllFolders"]</option>
                            @if (Model.SelectedAccountId.HasValue && Model.FolderOptions != null)
                            {
                                @foreach (var folder in Model.FolderOptions.Where(f => !string.IsNullOrEmpty(f.Value)))
                                {
                                    <option value="@folder.Value" selected="@folder.Selected">@folder.Text</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-12 col-md-6 @(Model.SelectedAccountId.HasValue ? "col-lg-1" : "col-lg-3") mb-3" id="directionFilterContainer">
                        <label asp-for="IsOutgoing" class="form-label">@Localizer["Direction"]</label>
                        <select asp-for="IsOutgoing" asp-items="Model.DirectionOptions" class="form-select form-select-sm"></select>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12">
                        <div class="d-flex flex-column flex-md-row justify-content-between gap-2">
                            <div class="d-flex flex-wrap gap-2">
                                <button type="submit" class="btn btn-primary btn-sm">
                                    <i class="bi bi-search"></i> @Localizer["Search"]
                                </button>
                                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">@Localizer["Reset"]</a>
                                <div class="form-check d-flex align-items-center ms-2">
                                    <input class="form-check-input me-2" type="checkbox" id="disableSelectionModeToggle" name="DisableSelectionMode" value="true"
                                           @(Model.DisableSelectionMode ? "checked" : "")>
                                    <label class="form-check-label small" for="disableSelectionModeToggle">@Localizer["Disable"] @Localizer["SelectionMode"]</label>
                                    <input type="hidden" id="userTimezone" name="UserTimezone" value="" />
                                    <input type="hidden" id="pageSizeHidden" name="PageSize" value="@Model.PageSize" />
                                    <input type="hidden" id="pageNumberHidden" name="PageNumber" value="@Model.PageNumber" />
                                    <input type="hidden" id="sortByHidden" name="SortBy" value="@Model.SortBy" />
                                    <input type="hidden" id="sortOrderHidden" name="SortOrder" value="@Model.SortOrder" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

        @await Html.PartialAsync("_EmailsLiveContent", Model)


<!-- Batch Restore Confirmation Modal -->
<div class="modal fade" id="batchRestoreConfirmModal" tabindex="-1" aria-labelledby="batchRestoreConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="batchRestoreConfirmModalLabel">@Localizer["ConfirmBatchRestore"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="confirmMessage"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Cancel"]</button>
                <button type="button" class="btn btn-primary" id="confirmBatchRestoreBtn">@Localizer["Continue"]</button>
            </div>
        </div>
    </div>
</div>

<!-- Export Format Selection Modal -->
<div class="modal fade" id="exportFormatModal" tabindex="-1" aria-labelledby="exportFormatModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exportFormatModalLabel">@Localizer["ExportSelected"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <h6>@Localizer["ExportFormatSelection"]</h6>
                    <p class="text-muted small">@Localizer["ExportFormatSelectionInfo"]</p>
                </div>
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="card h-100">
                            <div class="card-body">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="exportFormat" id="formatEML" value="EML" checked>
                                    <label class="form-check-label" for="formatEML">
                                        <strong>@Localizer["EMLFormat"]</strong>
                                    </label>
                                </div>
                                <small class="text-muted">@Localizer["EMLFormatDescription"]</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="card h-100">
                            <div class="card-body">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="exportFormat" id="formatMBox" value="MBox">
                                    <label class="form-check-label" for="formatMBox">
                                        <strong>@Localizer["MBoxFormat"]</strong>
                                    </label>
                                </div>
                                <small class="text-muted">@Localizer["MBoxFormatDescription"]</small>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="alert alert-info alert-persistent">
                    <small>
                        <i class="bi bi-info-circle me-1"></i>
                        @Localizer["ExportSelectedInfo"]
                    </small>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Cancel"]</button>
                <button type="button" class="btn btn-primary" id="confirmExportBtn">@Localizer["StartExport"]</button>
            </div>
        </div>
    </div>
</div>

<div class="offcanvas offcanvas-start folder-tree-offcanvas" tabindex="-1" id="folderTreeOffcanvas" aria-labelledby="folderTreeOffcanvasLabel">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="folderTreeOffcanvasLabel">
            <i class="bi bi-folder me-2"></i>@Localizer["Folders"]
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body p-0">
        <div class="folder-tree-content" id="folderTreeContentMobile">
            @await Html.PartialAsync("_FolderTreeContent", folderTree, new ViewDataDictionary(ViewData) { ["SelectedFolder"] = Model.SelectedFolder })
        </div>
    </div>
</div>
    </div>

@section Scripts {
    <script>
        (function () {
            function initializeEmailsPage() {
            console.log("Email selection script initialized");
                const timezoneInput = document.getElementById('userTimezone');
            if (timezoneInput) {
                timezoneInput.value = Intl.DateTimeFormat().resolvedOptions().timeZone;
            }

            const searchForm = document.getElementById('searchForm');
            const accountSelect = document.getElementById('accountSelect');
            const disableSelectionModeToggle = document.getElementById('disableSelectionModeToggle');
            const pageSizeHidden = document.getElementById('pageSizeHidden');
            const pageNumberHidden = document.getElementById('pageNumberHidden');
            const sortByHidden = document.getElementById('sortByHidden');
            const sortOrderHidden = document.getElementById('sortOrderHidden');
            const folderTreeColumn = document.getElementById('folderTreeColumn');
            const folderTreePanel = document.getElementById('folderTreePanel');
            const folderTreeHeader = document.getElementById('folderTreeHeader');
            const folderTreeToggleBtn = document.getElementById('folderTreeToggleBtn');
            const folderTreeMobileToggle = document.getElementById('folderTreeMobileToggle');
            const folderTreeContent = document.getElementById('folderTreeContent');
            const folderTreeContentMobile = document.getElementById('folderTreeContentMobile');
            const emailsResultsColumn = document.getElementById('emailsResultsColumn');
            const pageSizeSelect = document.getElementById('pageSizeSelect');
            let isEmailsIndexRefreshInFlight = false;

            function setFolderTreeAvailability(isAvailable) {
                if (folderTreeColumn) {
                    folderTreeColumn.classList.toggle('folder-tree-unavailable', !isAvailable);
                    folderTreeColumn.dataset.accountSelected = isAvailable ? 'true' : 'false';
                    if (!isAvailable) {
                        folderTreeColumn.classList.remove('collapsed-col');
                    }
                }

                if (folderTreeMobileToggle) {
                    folderTreeMobileToggle.classList.toggle('folder-tree-unavailable', !isAvailable);
                }

                if (folderTreeToggleBtn) {
                    folderTreeToggleBtn.classList.toggle('folder-tree-unavailable', !isAvailable);
                    if (!isAvailable) {
                        folderTreeToggleBtn.style.display = 'none';
                    }
                }

                if (emailsResultsColumn) {
                    emailsResultsColumn.classList.toggle('has-folder-tree', isAvailable);
                    emailsResultsColumn.classList.toggle('col-lg-10', isAvailable);
                    if (!isAvailable) {
                        emailsResultsColumn.classList.remove('expanded-col');
                    }
                }
            }

            function initializeFolderTreePanel() {
                const FOLDER_TREE_COLLAPSED_KEY = 'folderTreeCollapsed';

                function isFolderTreeCollapsed() {
                    try {
                        return localStorage.getItem(FOLDER_TREE_COLLAPSED_KEY) === 'true';
                    } catch (e) {
                        return false;
                    }
                }

                function saveFolderTreeState(collapsed) {
                    try {
                        localStorage.setItem(FOLDER_TREE_COLLAPSED_KEY, collapsed.toString());
                    } catch (e) {
                    }
                }

                function updateFolderTreeState(collapsed) {
                    if (folderTreePanel) {
                        folderTreePanel.classList.toggle('collapsed', collapsed);
                    }

                    if (folderTreeColumn) {
                        folderTreeColumn.classList.toggle('collapsed-col', collapsed);
                    }

                    if (emailsResultsColumn) {
                        emailsResultsColumn.classList.toggle('expanded-col', collapsed);
                    }

                    if (folderTreeHeader) {
                        folderTreeHeader.setAttribute('aria-expanded', (!collapsed).toString());
                    }

                    if (folderTreeToggleBtn) {
                        folderTreeToggleBtn.style.display = collapsed ? 'inline-flex' : 'none';
                        folderTreeToggleBtn.setAttribute('aria-expanded', (!collapsed).toString());
                    }
                }

                function toggleFolderTree(forceCollapsed) {
                    const collapsed = typeof forceCollapsed === 'boolean'
                        ? forceCollapsed
                        : !(folderTreePanel && folderTreePanel.classList.contains('collapsed'));

                    updateFolderTreeState(collapsed);
                    saveFolderTreeState(collapsed);
                }

                if (!folderTreePanel || !folderTreeColumn || !emailsResultsColumn) {
                    if (folderTreeToggleBtn) {
                        folderTreeToggleBtn.style.display = 'none';
                    }
                    return;
                }

                const isAvailable = folderTreeColumn.dataset.accountSelected === 'true' && !folderTreeColumn.classList.contains('folder-tree-unavailable');
                if (!isAvailable) {
                    folderTreePanel.classList.remove('collapsed');
                    folderTreeColumn.classList.remove('collapsed-col');
                    emailsResultsColumn.classList.remove('expanded-col');
                    if (folderTreeHeader) {
                        folderTreeHeader.setAttribute('aria-expanded', 'false');
                    }
                    if (folderTreeToggleBtn) {
                        folderTreeToggleBtn.style.display = 'none';
                        folderTreeToggleBtn.setAttribute('aria-expanded', 'false');
                    }
                    return;
                }

                updateFolderTreeState(isFolderTreeCollapsed());

                if (folderTreeHeader && folderTreeHeader.dataset.listenerInitialized !== 'true') {
                    folderTreeHeader.dataset.listenerInitialized = 'true';

                    folderTreeHeader.addEventListener('click', function(e) {
                        e.stopPropagation();
                        toggleFolderTree();
                    });

                    folderTreeHeader.addEventListener('keydown', function(e) {
                        if (e.key === 'Enter' || e.key === ' ') {
                            e.preventDefault();
                            toggleFolderTree();
                        }
                    });
                }

                if (folderTreeToggleBtn && folderTreeToggleBtn.dataset.listenerInitialized !== 'true') {
                    folderTreeToggleBtn.dataset.listenerInitialized = 'true';
                    folderTreeToggleBtn.addEventListener('click', function() {
                        toggleFolderTree(false);
                    });
                }
            }

            function setHiddenSearchState(name, value) {
                const fieldMap = {
                    PageSize: pageSizeHidden,
                    PageNumber: pageNumberHidden,
                    SortBy: sortByHidden,
                    SortOrder: sortOrderHidden
                };

                const field = fieldMap[name];
                if (field) {
                    field.value = value || '';
                }
            }

            function updateSelectFromResponse(currentSelect, replacementSelect) {
                if (!currentSelect || !replacementSelect) {
                    return;
                }

                currentSelect.innerHTML = replacementSelect.innerHTML;
                currentSelect.value = replacementSelect.value;
            }

            function replaceElementFromResponse(elementId, parsedDocument) {
                const currentElement = document.getElementById(elementId);
                const replacementElement = parsedDocument.getElementById(elementId);
                if (currentElement && replacementElement) {
                    currentElement.replaceWith(replacementElement);
                }
            }

            function syncSearchUiFromResponse(parsedDocument) {
                const replacementForm = parsedDocument.getElementById('searchForm');
                if (searchForm && replacementForm) {
                    ['SearchTerm', 'FromDate', 'ToDate', 'UserTimezone', 'PageSize', 'PageNumber', 'SortBy', 'SortOrder'].forEach(function(fieldName) {
                        const currentField = searchForm.elements[fieldName];
                        const replacementField = replacementForm.elements[fieldName];

                        if (!currentField || !replacementField) {
                            return;
                        }

                        if (currentField.type === 'checkbox') {
                            currentField.checked = replacementField.checked;
                        } else {
                            currentField.value = replacementField.value;
                        }
                    });

                    const replacementDisableSelectionMode = replacementForm.elements['DisableSelectionMode'];
                    if (disableSelectionModeToggle && replacementDisableSelectionMode) {
                        disableSelectionModeToggle.checked = replacementDisableSelectionMode.checked;
                    }

                    updateSelectFromResponse(accountSelect, replacementForm.querySelector('#accountSelect'));
                }

                replaceElementFromResponse('folderFilterContainer', parsedDocument);
                replaceElementFromResponse('directionFilterContainer', parsedDocument);
                replaceElementFromResponse('folderTreeMobileToggle', parsedDocument);

                const currentFolderTreeMobileContent = document.getElementById('folderTreeContentMobile');
                const replacementFolderTreeMobileContent = parsedDocument.getElementById('folderTreeContentMobile');
                if (currentFolderTreeMobileContent && replacementFolderTreeMobileContent) {
                    currentFolderTreeMobileContent.innerHTML = replacementFolderTreeMobileContent.innerHTML;
                }
            }

            async function refreshEmailsIndex(url, options) {
                const normalizedOptions = Object.assign({ pushState: true, replaceState: false }, options || {});
                const targetUrl = url instanceof URL ? url : new URL(url, window.location.origin);

                if (isEmailsIndexRefreshInFlight) {
                    return false;
                }

                isEmailsIndexRefreshInFlight = true;

                try {
                    const response = await fetch(targetUrl.toString(), {
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest',
                            'X-MailArchiver-Fragment': 'emailsLiveContent',
                            'Cache-Control': 'no-cache, no-store, max-age=0',
                            'Pragma': 'no-cache'
                        },
                        cache: 'no-store',
                        credentials: 'same-origin'
                    });

                    if (!response.ok) {
                        throw new Error('Failed to refresh emails index');
                    }

                    const html = await response.text();
                    const parsedDocument = new DOMParser().parseFromString(html, 'text/html');
                    const replacementLiveContent = parsedDocument.getElementById('emailsLiveContent');
                    const currentLiveContent = document.getElementById('emailsLiveContent');

                    if (!replacementLiveContent || !currentLiveContent) {
                        throw new Error('Could not find refreshed email results content');
                    }

                    syncSearchUiFromResponse(parsedDocument);
                    currentLiveContent.replaceWith(replacementLiveContent);

                    if (window.mailArchiver && typeof window.mailArchiver.initializeDynamicUi === 'function') {
                        window.mailArchiver.initializeDynamicUi(replacementLiveContent);
                    }

                    if (window.mailArchiver && typeof window.mailArchiver.initializeAutoRefresh === 'function') {
                        window.mailArchiver.initializeAutoRefresh(replacementLiveContent);
                    }

                    if (normalizedOptions.pushState) {
                        window.history.pushState({ emailsIndexUrl: targetUrl.toString() }, '', targetUrl.toString());
                    } else if (normalizedOptions.replaceState) {
                        window.history.replaceState({ emailsIndexUrl: targetUrl.toString() }, '', targetUrl.toString());
                    }

                    document.dispatchEvent(new CustomEvent('mailarchiver:fragment-refreshed', {
                        detail: {
                            containerId: 'emailsLiveContent',
                            element: replacementLiveContent,
                            manual: true
                        }
                    }));

                    return true;
                } catch (error) {
                    console.error('Error refreshing emails index:', error);
                    window.location.href = targetUrl.toString();
                    return false;
                } finally {
                    isEmailsIndexRefreshInFlight = false;
                }
            }

            function applyCurrentSearchFormState(url) {
                if (!searchForm) {
                    return url;
                }

                const formData = new FormData(searchForm);
                const scalarFields = ['SearchTerm', 'FromDate', 'ToDate', 'SelectedAccountId', 'SelectedFolder', 'IsOutgoing', 'UserTimezone', 'PageSize', 'PageNumber', 'SortBy', 'SortOrder'];

                scalarFields.forEach(function(fieldName) {
                    const value = formData.get(fieldName);
                    if (typeof value === 'string' && value !== '') {
                        url.searchParams.set(fieldName, value);
                    } else {
                        url.searchParams.delete(fieldName);
                    }
                });

                if (formData.get('DisableSelectionMode') === 'true') {
                    url.searchParams.set('DisableSelectionMode', 'true');
                } else {
                    url.searchParams.delete('DisableSelectionMode');
                }

                return url;
            }

            function buildSearchUrl(overrides) {
                const targetUrl = applyCurrentSearchFormState(new URL('@Url.Action("Index", "Emails")', window.location.origin));
                const effectiveOverrides = overrides || {};

                Object.entries(effectiveOverrides).forEach(function(entry) {
                    const key = entry[0];
                    const value = entry[1];

                    if (value === null || value === undefined || value === '') {
                        targetUrl.searchParams.delete(key);
                    } else {
                        targetUrl.searchParams.set(key, value);
                    }

                    setHiddenSearchState(key, value);
                });

                return targetUrl;
            }

            function initializeFolderTreeHandlers() {
                document.querySelectorAll('.folder-tree-item').forEach(function(item) {
                    if (item.dataset.listenerInitialized === 'true') {
                        return;
                    }

                    item.dataset.listenerInitialized = 'true';
                    item.addEventListener('click', function(e) {
                        if (e.target.closest('.folder-tree-toggle')) {
                            return;
                        }

                        const folder = this.dataset.folder;
                        if (!folder) {
                            return;
                        }

                        const currentAccountId = accountSelect ? accountSelect.value : '';
                        const targetUrl = buildSearchUrl({
                            SelectedAccountId: currentAccountId || '',
                            SelectedFolder: folder,
                            PageNumber: '1'
                        });

                        refreshEmailsIndex(targetUrl);
                    });
                });

                document.querySelectorAll('.folder-tree-toggle').forEach(function(toggle) {
                    if (toggle.dataset.listenerInitialized === 'true') {
                        return;
                    }

                    toggle.dataset.listenerInitialized = 'true';
                    toggle.addEventListener('click', function(e) {
                        e.stopPropagation();
                        const parent = this.closest('.folder-tree-item');
                        const children = parent ? parent.nextElementSibling : null;
                        if (children && children.classList.contains('folder-tree-children')) {
                            const isHidden = children.style.display === 'none';
                            children.style.display = isHidden ? 'block' : 'none';
                            this.classList.toggle('expanded', isHidden);
                        }
                    });
                });
            }

            function initializeFolderAndDirectionFiltering() {
                const currentAccountSelect = document.getElementById('accountSelect');
                const currentFolderContainer = document.getElementById('folderFilterContainer');
                const currentFolderSelect = document.getElementById('folderSelect');
                const currentDirectionContainer = document.getElementById('directionFilterContainer');

                if (currentAccountSelect && currentFolderContainer && currentFolderSelect && currentDirectionContainer) {
                    const currentAccountId = currentAccountSelect.value;
                    if (currentAccountId && currentAccountId !== '') {
                        currentDirectionContainer.className = 'col-12 col-md-6 col-lg-1 mb-3';
                        setFolderTreeAvailability(true);
                    } else {
                        currentDirectionContainer.className = 'col-12 col-md-6 col-lg-3 mb-3';
                        setFolderTreeAvailability(false);
                    }

                    if (currentAccountSelect.dataset.listenerInitialized !== 'true') {
                        currentAccountSelect.dataset.listenerInitialized = 'true';
                        currentAccountSelect.addEventListener('change', function() {
                            if (currentFolderSelect) {
                                currentFolderSelect.value = '';
                            }

                            const targetUrl = buildSearchUrl({
                                SelectedAccountId: this.value || '',
                                SelectedFolder: '',
                                PageNumber: '1'
                            });

                            refreshEmailsIndex(targetUrl);
                        });
                    }

                    if (currentFolderSelect.dataset.listenerInitialized !== 'true') {
                        currentFolderSelect.dataset.listenerInitialized = 'true';
                        currentFolderSelect.addEventListener('change', function() {
                            const targetUrl = buildSearchUrl({
                                SelectedFolder: this.value || '',
                                PageNumber: '1'
                            });

                            refreshEmailsIndex(targetUrl);
                        });
                    }
                }
            }

            function initializeSearchNavigation() {
                const currentPageSizeSelect = document.getElementById('pageSizeSelect');
                if (currentPageSizeSelect && pageSizeHidden && currentPageSizeSelect.dataset.listenerInitialized !== 'true') {
                    currentPageSizeSelect.dataset.listenerInitialized = 'true';
                    currentPageSizeSelect.addEventListener('change', function() {
                        const targetUrl = buildSearchUrl({
                            PageSize: this.value,
                            PageNumber: '1'
                        });

                        refreshEmailsIndex(targetUrl);
                    });
                }

                if (searchForm && searchForm.dataset.listenerInitialized !== 'true') {
                    searchForm.dataset.listenerInitialized = 'true';
                    searchForm.addEventListener('submit', function(e) {
                        e.preventDefault();
                        const targetUrl = buildSearchUrl({ PageNumber: pageNumberHidden ? pageNumberHidden.value || '1' : '1' });
                        refreshEmailsIndex(targetUrl);
                    });
                }

                if (disableSelectionModeToggle && disableSelectionModeToggle.dataset.listenerInitialized !== 'true') {
                    disableSelectionModeToggle.dataset.listenerInitialized = 'true';
                    disableSelectionModeToggle.addEventListener('change', function() {
                        clearStoredSelections();
                        const targetUrl = buildSearchUrl({ PageNumber: '1' });
                        refreshEmailsIndex(targetUrl);
                    });
                }

                if (document.body.dataset.emailsIndexNavigationInitialized !== 'true') {
                    document.body.dataset.emailsIndexNavigationInitialized = 'true';

                    document.addEventListener('click', function(event) {
                        const paginationLink = event.target.closest('#emailsLiveContent .page-link[href]');
                        if (paginationLink) {
                            event.preventDefault();
                            refreshEmailsIndex(new URL(paginationLink.href, window.location.origin));
                            return;
                        }

                        const sortTrigger = event.target.closest('#emailsLiveContent .email-search-sort-trigger[data-email-search-url]');
                        if (sortTrigger) {
                            event.preventDefault();
                            const sortBy = sortTrigger.dataset.sortBy || '';
                            const sortOrder = sortTrigger.dataset.sortOrder || '';
                            if (sortBy) {
                                setHiddenSearchState('SortBy', sortBy);
                            }
                            if (sortOrder) {
                                setHiddenSearchState('SortOrder', sortOrder);
                            }
                            setHiddenSearchState('PageNumber', '1');
                            refreshEmailsIndex(new URL(sortTrigger.dataset.emailSearchUrl, window.location.origin));
                        }
                    });

                    document.addEventListener('keydown', function(event) {
                        const sortTrigger = event.target.closest('#emailsLiveContent .email-search-sort-trigger[data-email-search-url]');
                        if (!sortTrigger) {
                            return;
                        }

                        if (event.key === 'Enter' || event.key === ' ') {
                            event.preventDefault();
                            sortTrigger.click();
                        }
                    });

                    window.addEventListener('popstate', function() {
                        refreshEmailsIndex(new URL(window.location.href), { pushState: false, replaceState: true });
                    });
                }
            }

            initializeFolderTreePanel();
            initializeFolderTreeHandlers();
            initializeFolderAndDirectionFiltering();
            initializeSearchNavigation();

            // Configuration from ViewBag
            const asyncThreshold = @ViewBag.AsyncThreshold;
            const maxAsyncEmails = @ViewBag.MaxAsyncEmails;
            const maxSelectableEmails = @(ViewBag.MaxSelectableEmails ?? 250);
            
            // Cross-page selection storage key
            const STORAGE_KEY = 'emailSelection';
            
            // Get elements
            const selectAllCheckbox = document.getElementById('selectAllCheckbox');
            const selectAllBtn = document.getElementById('selectAllBtn');
            const deselectAllBtn = document.getElementById('deselectAllBtn');
            const selectionCounter = document.getElementById('selectionCounter');
            const selectionActions = document.getElementById('selectionActions');
            const batchRestoreBtn = document.getElementById('batchRestoreBtn');
            const operationMode = document.getElementById('operationMode');

            console.log("Selection controls visible: " + @(Model.ShowSelectionControls ? "true" : "false"));
            console.log("Max selectable emails: " + maxSelectableEmails);

            // Cross-page selection management
            function getStoredSelections() {
                try {
                    const stored = localStorage.getItem(STORAGE_KEY);
                    return stored ? JSON.parse(stored) : [];
                } catch (e) {
                    console.warn('Error reading stored selections:', e);
                    return [];
                }
            }

            function saveStoredSelections(selections) {
                try {
                    localStorage.setItem(STORAGE_KEY, JSON.stringify(selections));
                } catch (e) {
                    console.warn('Error saving selections:', e);
                }
            }

            function addToStoredSelections(emailIds) {
                const stored = getStoredSelections();
                const updated = [...new Set([...stored, ...emailIds])]; // Remove duplicates
                
                // Enforce maximum limit
                if (updated.length > maxSelectableEmails) {
                    const message = '@Localizer["MaxSelectionsReached"]'.replace('{0}', maxSelectableEmails);
                    alert(message);
                    return false;
                }
                
                saveStoredSelections(updated);
                return true;
            }

            function removeFromStoredSelections(emailIds) {
                const stored = getStoredSelections();
                const updated = stored.filter(id => !emailIds.includes(id));
                saveStoredSelections(updated);
            }

            function clearStoredSelections() {
                localStorage.removeItem(STORAGE_KEY);
            }

            function getTotalSelectedCount() {
                return getStoredSelections().length;
            }

            // Update button texts based on selection state
            function updateButtonTexts() {
                const emailCheckboxes = document.querySelectorAll('.email-select-checkbox');
                const currentPageIds = Array.from(emailCheckboxes).map(cb => cb.value);
                const storedSelections = getStoredSelections();
                const currentPageSelected = currentPageIds.filter(id => storedSelections.includes(id));
                
                if (selectAllBtn) {
                    if (currentPageSelected.length === currentPageIds.length) {
                        selectAllBtn.innerHTML = '@Html.Raw(Localizer["DeselectAllOnPage"].Value)';
                        selectAllBtn.className = 'btn btn-sm btn-outline-secondary';
                    } else {
                        selectAllBtn.innerHTML = '@Html.Raw(Localizer["SelectAllOnPage"].Value)';
                        selectAllBtn.className = 'btn btn-sm btn-outline-primary';
                    }
                }
            }

            // Update selection counter and mode indicator
            function updateSelectionCounter() {
                const totalSelected = getTotalSelectedCount();
                const emailCheckboxes = document.querySelectorAll('.email-select-checkbox');
                const checkedBoxes = document.querySelectorAll('.email-select-checkbox:checked');
                
                console.log("Total selected across all pages: " + totalSelected);
                console.log("Selected on current page: " + checkedBoxes.length);
                
                if (selectionCounter) {
                    if (totalSelected >= maxSelectableEmails) {
                        selectionCounter.innerHTML = '@Html.Raw(Localizer["MaxSelectionsReached"].Value)'.replace('{0}', maxSelectableEmails);
                        selectionCounter.className = 'badge bg-warning';
                    } else {
                        selectionCounter.innerHTML = '@Html.Raw(Localizer["SelectedOf"].Value)'.replace('{0}', totalSelected).replace('{1}', maxSelectableEmails);
                        selectionCounter.className = 'badge bg-primary';
                    }
                }

                // Update operation mode indicator
                if (operationMode && totalSelected > 0) {
                    operationMode.style.display = 'inline';
                    if (totalSelected <= asyncThreshold) {
                        operationMode.textContent = '@Localizer["DirectProcessingMode"]';
                        operationMode.className = 'badge bg-success';
                    } else if (totalSelected <= maxAsyncEmails) {
                        operationMode.textContent = '@Localizer["BackgroundJobMode"]';
                        operationMode.className = 'badge bg-primary';
                    } else {
                        operationMode.textContent = '@Localizer["TooManySelected"]';
                        operationMode.className = 'badge bg-danger';
                    }
                } else if (operationMode) {
                    operationMode.style.display = 'none';
                }

                // Show/hide batch actions
                if (selectionActions) {
                    if (totalSelected > 0) {
                        selectionActions.style.display = 'block';
                        
                        // Update button state based on count
                        if (batchRestoreBtn) {
                            if (totalSelected > maxAsyncEmails) {
                                batchRestoreBtn.disabled = true;
                                batchRestoreBtn.innerHTML = '<i class="bi bi-exclamation-triangle"></i> <span class="d-inline">@Localizer["TooManySelected"]</span>';
                                batchRestoreBtn.className = 'btn btn-sm btn-danger me-2';
                            } else {
                                batchRestoreBtn.disabled = false;
                                batchRestoreBtn.innerHTML = '<i class="bi bi-envelope-arrow-up"></i> <span class="d-inline">@Localizer["CopySelected"]</span>';
                                batchRestoreBtn.className = 'btn btn-sm btn-success me-2';
                            }
                        }
                    } else {
                        selectionActions.style.display = 'none';
                    }
                }

                // Update select all checkbox state on current page
                if (selectAllCheckbox && emailCheckboxes.length > 0) {
                    selectAllCheckbox.checked = checkedBoxes.length === emailCheckboxes.length;
                    selectAllCheckbox.indeterminate = checkedBoxes.length > 0 && checkedBoxes.length < emailCheckboxes.length;
                }

                updateButtonTexts();
            }

            // Initialize counter and attach events
            function initializeSelectionHandlers() {
                const emailCheckboxes = document.querySelectorAll('.email-select-checkbox');
                const storedSelections = getStoredSelections();
                
                console.log("Found email checkboxes: " + emailCheckboxes.length);
                console.log("Stored selections: ", storedSelections);

                // Restore selections for current page
                emailCheckboxes.forEach(function(checkbox) {
                    if (storedSelections.includes(checkbox.value)) {
                        checkbox.checked = true;
                    }
                    
                    // Individual checkbox change
                    if (checkbox.dataset.listenerInitialized === 'true') {
                        return;
                    }

                    checkbox.dataset.listenerInitialized = 'true';
                    checkbox.addEventListener('change', function() {
                        const isChecked = this.checked;
                        const emailId = this.value;
                        
                        if (isChecked) {
                            if (!addToStoredSelections([emailId])) {
                                // Maximum reached, uncheck the box
                                this.checked = false;
                                return;
                            }
                        } else {
                            removeFromStoredSelections([emailId]);
                        }
                        
                        updateSelectionCounter();
                    });
                });

                updateSelectionCounter();
            }

            // Select/deselect all checkboxes on current page
            if (selectAllCheckbox && selectAllCheckbox.dataset.listenerInitialized !== 'true') {
                selectAllCheckbox.dataset.listenerInitialized = 'true';
                selectAllCheckbox.addEventListener('change', function() {
                    const isChecked = this.checked;
                    const emailCheckboxes = document.querySelectorAll('.email-select-checkbox');
                    const currentPageIds = Array.from(emailCheckboxes).map(cb => cb.value);
                    
                    if (isChecked) {
                        // Try to add all current page IDs
                        if (addToStoredSelections(currentPageIds)) {
                            emailCheckboxes.forEach(function(checkbox) {
                                checkbox.checked = true;
                            });
                        } else {
                            // If we can't add all, uncheck the select all box
                            this.checked = false;
                        }
                    } else {
                        // Remove all current page IDs
                        removeFromStoredSelections(currentPageIds);
                        emailCheckboxes.forEach(function(checkbox) {
                            checkbox.checked = false;
                        });
                    }
                    
                    updateSelectionCounter();
                });
            }

            // Select all button - only for current page
            if (selectAllBtn && selectAllBtn.dataset.listenerInitialized !== 'true') {
                selectAllBtn.dataset.listenerInitialized = 'true';
                selectAllBtn.addEventListener('click', function() {
                    const emailCheckboxes = document.querySelectorAll('.email-select-checkbox');
                    const currentPageIds = Array.from(emailCheckboxes).map(cb => cb.value);
                    const storedSelections = getStoredSelections();
                    const currentPageSelected = currentPageIds.filter(id => storedSelections.includes(id));
                    
                    if (currentPageSelected.length === currentPageIds.length) {
                        // All are selected, deselect all on current page
                        removeFromStoredSelections(currentPageIds);
                        emailCheckboxes.forEach(function(checkbox) {
                            checkbox.checked = false;
                        });
                    } else {
                        // Not all are selected, select all on current page
                        if (addToStoredSelections(currentPageIds)) {
                            emailCheckboxes.forEach(function(checkbox) {
                                checkbox.checked = true;
                            });
                        }
                    }
                    
                    updateSelectionCounter();
                });
            }

            // Deselect all button - clears all selections across all pages
            if (deselectAllBtn && deselectAllBtn.dataset.listenerInitialized !== 'true') {
                deselectAllBtn.dataset.listenerInitialized = 'true';
                deselectAllBtn.addEventListener('click', function() {
                    clearStoredSelections();
                    const emailCheckboxes = document.querySelectorAll('.email-select-checkbox');
                    emailCheckboxes.forEach(function(checkbox) {
                        checkbox.checked = false;
                    });
                    updateSelectionCounter();
                });
            }

            // Batch restore button
            if (batchRestoreBtn && batchRestoreBtn.dataset.listenerInitialized !== 'true') {
                batchRestoreBtn.dataset.listenerInitialized = 'true';
                batchRestoreBtn.addEventListener('click', function() {
                    if (this.disabled) {
                        return;
                    }

                    const totalSelected = getTotalSelectedCount();
                    const storedSelections = getStoredSelections();
                    
                    if (totalSelected === 0) {
                        // Show modal for no emails selected
                        document.getElementById('confirmMessage').innerHTML = '@Html.Raw(Localizer["PleaseSelectAtLeastOne"].Value)';
                        var confirmModal = new bootstrap.Modal(document.getElementById('batchRestoreConfirmModal'));
                        document.getElementById('confirmBatchRestoreBtn').style.display = 'none';
                        confirmModal.show();
                        
                        // Hide modal after 3 seconds
                        setTimeout(function() {
                            confirmModal.hide();
                        }, 3000);
                        return;
                    }

                    if (totalSelected > maxAsyncEmails) {
                        // Show modal for too many emails selected
                        const tooManyMessage = '@Html.Raw(Localizer["TooManyEmailsSelected"].Value)'.replace('{0}', totalSelected.toLocaleString()).replace('{1}', maxAsyncEmails.toLocaleString());
                        document.getElementById('confirmMessage').innerHTML = tooManyMessage;
                        var confirmModal = new bootstrap.Modal(document.getElementById('batchRestoreConfirmModal'));
                        document.getElementById('confirmBatchRestoreBtn').style.display = 'none';
                        confirmModal.show();
                        
                        // Hide modal after 5 seconds
                        setTimeout(function() {
                            confirmModal.hide();
                        }, 5000);
                        return;
                    }

                    // Show confirmation for large operations
                    if (totalSelected > asyncThreshold) {
                        // Show confirmation modal
                        const message = '@Html.Raw(Localizer["ContinueWithOperation"].Value)'.replace('{0}', totalSelected.toLocaleString());
                        document.getElementById('confirmMessage').innerHTML = message;
                        var confirmModal = new bootstrap.Modal(document.getElementById('batchRestoreConfirmModal'));
                        document.getElementById('confirmBatchRestoreBtn').style.display = 'inline-block';
                        
                        // Handle confirmation
                        document.getElementById('confirmBatchRestoreBtn').onclick = function() {
                            confirmModal.hide();
                            submitBatchRestoreForm(storedSelections);
                        };
                        
                        confirmModal.show();
                        return;
                    }
                    
                    // For small operations, proceed directly
                    submitBatchRestoreForm(storedSelections);
                });
            }

            // Export selected button
            const exportSelectedBtn = document.getElementById('exportSelectedBtn');
            if (exportSelectedBtn && exportSelectedBtn.dataset.listenerInitialized !== 'true') {
                exportSelectedBtn.dataset.listenerInitialized = 'true';
                exportSelectedBtn.addEventListener('click', function() {
                    const totalSelected = getTotalSelectedCount();
                    const storedSelections = getStoredSelections();
                    
                    if (totalSelected === 0) {
                        // Show modal for no emails selected
                        document.getElementById('confirmMessage').innerHTML = '@Html.Raw(Localizer["PleaseSelectAtLeastOne"].Value)';
                        var confirmModal = new bootstrap.Modal(document.getElementById('batchRestoreConfirmModal'));
                        document.getElementById('confirmBatchRestoreBtn').style.display = 'none';
                        confirmModal.show();
                        
                        // Hide modal after 3 seconds
                        setTimeout(function() {
                            confirmModal.hide();
                        }, 3000);
                        return;
                    }

                    // Show export format selection modal
                    var exportFormatModal = new bootstrap.Modal(document.getElementById('exportFormatModal'));
                    exportFormatModal.show();
                    
                    // Store the selected IDs for later use
                    window.selectedEmailsForExport = storedSelections;
                });
            }

            // Export format confirmation button
            const confirmExportBtn = document.getElementById('confirmExportBtn');
            if (confirmExportBtn && confirmExportBtn.dataset.listenerInitialized !== 'true') {
                confirmExportBtn.dataset.listenerInitialized = 'true';
                confirmExportBtn.addEventListener('click', function() {
                    const selectedFormat = document.querySelector('input[name="exportFormat"]:checked').value;
                    const selectedIds = window.selectedEmailsForExport;
                    
                    // Close the modal
                    var exportFormatModal = bootstrap.Modal.getInstance(document.getElementById('exportFormatModal'));
                    exportFormatModal.hide();
                    
                    // Submit export form with selected format
                    submitExportForm(selectedIds, selectedFormat);
                });
            }

            // Delete selected button
            const deleteSelectedBtn = document.getElementById('deleteSelectedBtn');
            if (deleteSelectedBtn && deleteSelectedBtn.dataset.listenerInitialized !== 'true') {
                deleteSelectedBtn.dataset.listenerInitialized = 'true';
                deleteSelectedBtn.addEventListener('click', function() {
                    const totalSelected = getTotalSelectedCount();
                    const storedSelections = getStoredSelections();
                    
                    if (totalSelected === 0) {
                        // Show modal for no emails selected
                        document.getElementById('confirmMessage').innerHTML = '@Html.Raw(Localizer["PleaseSelectAtLeastOne"].Value)';
                        var confirmModal = new bootstrap.Modal(document.getElementById('batchRestoreConfirmModal'));
                        document.getElementById('confirmBatchRestoreBtn').style.display = 'none';
                        confirmModal.show();
                        
                        // Hide modal after 3 seconds
                        setTimeout(function() {
                            confirmModal.hide();
                        }, 3000);
                        return;
                    }

                    // Show confirmation modal for deletion
                    const deleteConfirmMessage = '@Html.Raw(Localizer["DeleteSelectedEmailsConfirm"].Value)'.replace('{0}', totalSelected.toLocaleString());
                    document.getElementById('confirmMessage').innerHTML = deleteConfirmMessage;
                    var confirmModal = new bootstrap.Modal(document.getElementById('batchRestoreConfirmModal'));
                    document.getElementById('confirmBatchRestoreBtn').style.display = 'inline-block';
                    
                    // Handle confirmation
                    document.getElementById('confirmBatchRestoreBtn').onclick = function() {
                        confirmModal.hide();
                        submitDeleteForm(storedSelections);
                    };
                    
                    confirmModal.show();
                });
            }

            // Function to submit the delete form
            function submitDeleteForm(selectedIds) {
                // Create a new form for POST request
                const form = document.createElement('form');
                form.method = 'post';
                form.action = '@Url.Action("DeleteSelected", "Emails")';
                
                // Add anti-forgery token
                const tokenInput = document.createElement('input');
                tokenInput.type = 'hidden';
                tokenInput.name = '__RequestVerificationToken';
                tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
                form.appendChild(tokenInput);

                // Add ReturnUrl
                const returnUrlInput = document.createElement('input');
                returnUrlInput.type = 'hidden';
                returnUrlInput.name = 'returnUrl';
                returnUrlInput.value = '@Context.Request.Path@Context.Request.QueryString';
                form.appendChild(returnUrlInput);

                // Add all selected IDs
                selectedIds.forEach(function(emailId) {
                    const idInput = document.createElement('input');
                    idInput.type = 'hidden';
                    idInput.name = 'ids';
                    idInput.value = emailId;
                    form.appendChild(idInput);
                });

                // Add form to body and submit
                document.body.appendChild(form);
                form.submit();
            }

            // Function to submit the batch restore form
            function submitBatchRestoreForm(selectedIds) {
                // Create a new form for POST request
                const form = document.createElement('form');
                form.method = 'post';
                form.action = '@Url.Action("BatchRestoreStart", "Emails")';
                
                // Add anti-forgery token
                const tokenInput = document.createElement('input');
                tokenInput.type = 'hidden';
                tokenInput.name = '__RequestVerificationToken';
                tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
                form.appendChild(tokenInput);

                // Add ReturnUrl
                const returnUrlInput = document.createElement('input');
                returnUrlInput.type = 'hidden';
                returnUrlInput.name = 'returnUrl';
                returnUrlInput.value = '@Context.Request.Path@Context.Request.QueryString';
                form.appendChild(returnUrlInput);

                // Add all selected IDs
                selectedIds.forEach(function(emailId) {
                    const idInput = document.createElement('input');
                    idInput.type = 'hidden';
                    idInput.name = 'ids';
                    idInput.value = emailId;
                    form.appendChild(idInput);
                });

                // Add form to body and submit
                document.body.appendChild(form);
                form.submit();
            }

            // Function to submit the export form
            function submitExportForm(selectedIds, selectedFormat) {
                // Create a new form for POST request
                const form = document.createElement('form');
                form.method = 'post';
                form.action = '@Url.Action("ExportSelected", "Emails")';
                
                // Add anti-forgery token
                const tokenInput = document.createElement('input');
                tokenInput.type = 'hidden';
                tokenInput.name = '__RequestVerificationToken';
                tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
                form.appendChild(tokenInput);

                // Add export format
                const formatInput = document.createElement('input');
                formatInput.type = 'hidden';
                formatInput.name = 'format';
                formatInput.value = selectedFormat;
                form.appendChild(formatInput);

                // Add ReturnUrl
                const returnUrlInput = document.createElement('input');
                returnUrlInput.type = 'hidden';
                returnUrlInput.name = 'returnUrl';
                returnUrlInput.value = '@Context.Request.Path@Context.Request.QueryString';
                form.appendChild(returnUrlInput);

                // Add all selected IDs
                selectedIds.forEach(function(emailId) {
                    const idInput = document.createElement('input');
                    idInput.type = 'hidden';
                    idInput.name = 'ids';
                    idInput.value = emailId;
                    form.appendChild(idInput);
                });

                // Add form to body and submit
                document.body.appendChild(form);
                form.submit();
            }

                // Initialize selection handlers when in selection mode
                @if (Model.ShowSelectionControls) {
                    <text>
                    initializeSelectionHandlers();
                    </text>
                }
            }

            document.addEventListener('DOMContentLoaded', initializeEmailsPage);
            document.addEventListener('mailarchiver:fragment-refreshed', function (event) {
                if (event.detail && event.detail.containerId === 'emailsLiveContent') {
                    initializeEmailsPage();
                }
            });
        })();
    </script>
}
