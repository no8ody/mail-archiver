@using MailArchiver.Services
@inject MailArchiver.Services.IAuthenticationService AuthService
@inject Microsoft.Extensions.Localization.IStringLocalizer<MailArchiver.SharedResource> Localizer
@model MailArchiver.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = Localizer["Dashboard"]; }

<div class="container-fluid">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-2">
        <h1 class="h3 mb-0">@Localizer["Dashboard"]</h1>
        <div>
            <a asp-controller="Emails" asp-action="Index" class="btn btn-primary btn-sm">
                <i class="bi bi-search"></i> <span class="d-none d-sm-inline">@Localizer["Search"]</span> @Localizer["Archive"]
            </a>
        </div>
    </div>

        @await Html.PartialAsync("_DashboardLiveContent", Model)

</div>

@section Scripts {
    <script src="~/lib/chart.js/chart.js"></script>
    <script>
        (function () {
            let monthlyChartInstance = null;
            let topSendersChartInstance = null;

            function destroyCharts() {
                if (monthlyChartInstance) {
                    monthlyChartInstance.destroy();
                    monthlyChartInstance = null;
                }

                if (topSendersChartInstance) {
                    topSendersChartInstance.destroy();
                    topSendersChartInstance = null;
                }
            }

            function renderDashboardCharts() {
                const container = document.getElementById('dashboardLiveContent');
                if (!container) {
                    destroyCharts();
                    return;
                }

                const chartDataElement = container.querySelector('#dashboardChartData');
                if (!chartDataElement) {
                    destroyCharts();
                    return;
                }

                let chartData;
                try {
                    chartData = JSON.parse(chartDataElement.textContent);
                } catch (error) {
                    console.error('Could not parse dashboard chart data.', error);
                    return;
                }

                const chartColors = {
                    blue: 'rgba(13, 110, 253, 0.8)',
                    blueBorder: 'rgba(13, 110, 253, 1)',
                    colors: [
                        'rgba(220, 53, 69, 0.8)',
                        'rgba(13, 110, 253, 0.8)',
                        'rgba(255, 193, 7, 0.8)',
                        'rgba(25, 135, 84, 0.8)',
                        'rgba(102, 16, 242, 0.8)',
                        'rgba(253, 126, 20, 0.8)',
                        'rgba(111, 66, 193, 0.8)',
                        'rgba(214, 51, 132, 0.8)',
                        'rgba(32, 201, 151, 0.8)',
                        'rgba(111, 66, 193, 0.8)'
                    ],
                    colorsBorder: [
                        'rgba(220, 53, 69, 1)',
                        'rgba(13, 110, 253, 1)',
                        'rgba(255, 193, 7, 1)',
                        'rgba(25, 135, 84, 1)',
                        'rgba(102, 16, 242, 1)',
                        'rgba(253, 126, 20, 1)',
                        'rgba(111, 66, 193, 1)',
                        'rgba(214, 51, 132, 1)',
                        'rgba(32, 201, 151, 1)',
                        'rgba(111, 66, 193, 1)'
                    ]
                };

                destroyCharts();

                const monthlyChartCanvas = container.querySelector('#monthlyChart');
                if (monthlyChartCanvas) {
                    monthlyChartInstance = new Chart(monthlyChartCanvas.getContext('2d'), {
                        type: 'bar',
                        data: {
                            labels: chartData.monthlyLabels || [],
                            datasets: [{
                                label: 'Emails',
                                data: chartData.monthlyData || [],
                                backgroundColor: chartColors.blue,
                                borderColor: chartColors.blueBorder,
                                borderWidth: 1,
                                borderRadius: 4
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    display: false
                                }
                            },
                            scales: {
                                x: {
                                    ticks: {
                                        maxRotation: 45,
                                        minRotation: 0,
                                        font: {
                                            size: window.innerWidth < 768 ? 10 : 12
                                        }
                                    }
                                },
                                y: {
                                    beginAtZero: true,
                                    ticks: {
                                        precision: 0,
                                        font: {
                                            size: window.innerWidth < 768 ? 10 : 12
                                        }
                                    }
                                }
                            }
                        }
                    });
                }

                const topSendersChartCanvas = container.querySelector('#topSendersChart');
                if (topSendersChartCanvas) {
                    topSendersChartInstance = new Chart(topSendersChartCanvas.getContext('2d'), {
                        type: 'doughnut',
                        data: {
                            labels: chartData.topSenderLabels || [],
                            datasets: [{
                                data: chartData.topSenderData || [],
                                backgroundColor: chartColors.colors,
                                borderColor: chartColors.colorsBorder,
                                borderWidth: 1,
                                hoverOffset: 4
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    position: 'bottom',
                                    labels: {
                                        boxWidth: 12,
                                        font: {
                                            size: window.innerWidth < 768 ? 9 : 11
                                        },
                                        padding: window.innerWidth < 768 ? 10 : 15
                                    }
                                },
                                tooltip: {
                                    callbacks: {
                                        label: function (context) {
                                            const label = context.label || '';
                                            const value = context.parsed || 0;
                                            const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                            const percentage = total > 0 ? Math.round((value * 100) / total) : 0;
                                            return `${label}: ${value} (${percentage}%)`;
                                        }
                                    }
                                }
                            }
                        }
                    });
                }
            }

            document.addEventListener('DOMContentLoaded', renderDashboardCharts);
            document.addEventListener('mailarchiver:fragment-refreshed', function (event) {
                if (event.detail && event.detail.containerId === 'dashboardLiveContent') {
                    renderDashboardCharts();
                }
            });
        })();
    </script>
}
