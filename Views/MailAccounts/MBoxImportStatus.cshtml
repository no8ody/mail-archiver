@inject Microsoft.Extensions.Localization.IStringLocalizer<MailArchiver.SharedResource> Localizer
@model MailArchiver.Models.MBoxImportJob
@{
    ViewData["Title"] = Localizer["MBoxImportStatusTitle"];
    var shouldAutoRefresh = Model.Status == MailArchiver.Models.MBoxImportJobStatus.Running || Model.Status == MailArchiver.Models.MBoxImportJobStatus.Queued;
}

<div class="container">
        @await Html.PartialAsync("_MBoxImportStatusLiveContent", Model)

    </div>

@functions {
    string FormatFileSize(long bytes)
    {
        string[] suffixes = { "B", "KB", "MB", "GB", "TB" };
        int counter = 0;
        decimal number = bytes;
        while (Math.Round(number / 1024) >= 1)
        {
            number /= 1024;
            counter++;
        }
        return $"{number:n1} {suffixes[counter]}";
    }
}

<!-- Bootstrap Modal for Cancel Confirmation -->
<div class="modal fade" id="cancelImportModal" tabindex="-1" aria-labelledby="cancelImportModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="cancelImportModalLabel">@Localizer["CancelImport"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @Localizer["CancelImportConfirm"]
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Close"]</button>
                <form asp-action="CancelMBoxImport" method="post" style="display: inline;">
                    <input type="hidden" name="jobId" value="@Model.JobId" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                    <button type="submit" class="btn btn-warning">
                        @Localizer["CancelImport"]
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
