{
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Database=MailArchiver;Username=mailuser;Password=masterkey"
  },
  "Authentication": {
    "Username": "admin",
    "Password": "secure123!",
    "SessionTimeoutMinutes": 60,
    "CookieName": "MailArchiverAuth",
    "CookieSameSite": "Strict",
    "CookieSecurePolicy": "SameAsRequest",
    "PublicOrigin": ""
  },
  "OAuth": {
    "Enabled": false,
    "Authority": "",
    "ClientId": "",
    "ClientSecret": null,
    "ClientScopes": [
      "openid",
      "profile",
      "email"
    ],
    "DisablePasswordLogin": false,
    "AutoRedirect": false,
    "AutoApproveUsers": false,
    "AdminEmails": []
  },
  "MailSync": {
    "IntervalMinutes": 15,
    "TimeoutMinutes": 120,
    "ConnectionTimeoutSeconds": 300,
    "CommandTimeoutSeconds": 600,
    "AlwaysForceFullSync": false,
    "IgnoreSelfSignedCert": false
  },
  "BatchRestore": {
    "AsyncThreshold": 50,
    "MaxSyncEmails": 150,
    "MaxAsyncEmails": 50000,
    "SessionTimeoutMinutes": 30,
    "DefaultBatchSize": 50
  },
  "Selection": {
    "MaxSelectableEmails": 250
  },
  "View": {
    "DefaultToPlainText": true,
    "BlockExternalResources": true
  },
  "BatchOperation": {
    "BatchSize": 50,
    "PauseBetweenEmailsMs": 50,
    "PauseBetweenBatchesMs": 200
  },
  "BandwidthTracking": {
    "Enabled": false,
    "DailyLimitMb": 25000,
    "WarningThresholdPercent": 80,
    "PauseHoursOnLimit": 24,
    "TrackUploadBytes": false
  },
  "TimeZone": {
    "DisplayTimeZoneId": "Etc/UCT"
  },
  "DatabaseMaintenance": {
    "Enabled": false,
    "DailyExecutionTime": "02:00",
    "TimeoutMinutes": 30
  },
  "Upload": {
    "MaxFileSizeGB": 2,
    "KeepAliveTimeoutMinutes": 10,
    "RequestHeadersTimeoutSeconds": 30,
    "MemoryBufferThresholdMB": 1,
    "MaxArchiveEntries": 10000,
    "MaxArchiveEntrySizeMB": 50,
    "MaxArchiveExpandedSizeGB": 2,
    "MaxArchiveCompressionRatio": 100,
    "Notes": "Security-hardened upload defaults with bounded ZIP processing"
  },
  "ReverseProxy": {
    "ForwardLimit": 1,
    "RequireHeaderSymmetry": true,
    "KnownProxies": [],
    "KnownNetworks": []
  },
  "Npgsql": {
    "CommandTimeout": 900
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "localhost;127.0.0.1;[::1]",
  "Encryption": {
    "Key": ""
  }
}
